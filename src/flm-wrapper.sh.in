#!/bin/bash
# Wrapper script for the FLM portable build
# Sets XILINX_XRT so XRT can find its bundled libraries at $XILINX_XRT/lib/x86_64-linux-gnu/

# Determine the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# XRT constructs library paths as $XILINX_XRT/lib/x86_64-linux-gnu/<lib>
# Point XILINX_XRT to the portable root so XRT finds ./lib/x86_64-linux-gnu/
export XILINX_XRT="$SCRIPT_DIR"

# Add bundled libraries to LD_LIBRARY_PATH for runtime resolution
export LD_LIBRARY_PATH="$SCRIPT_DIR/lib:$LD_LIBRARY_PATH"

# Ensure the multiarch directory structure exists with symlinks to bundled libs
MULTIARCH_DIR="$SCRIPT_DIR/lib/x86_64-linux-gnu"
if [ ! -d "$MULTIARCH_DIR" ]; then
    mkdir -p "$MULTIARCH_DIR"
    cd "$SCRIPT_DIR/lib"
    for lib in libxrt*.so* libxrt++.so*; do
        if [ -f "$lib" ] || [ -L "$lib" ]; then
            # Handle symlinks by following them to get the actual target
            if [ -L "$lib" ]; then
                target=$(readlink "$lib")
                ln -sf "../$target" "$MULTIARCH_DIR/$lib" 2>/dev/null
            else
                ln -sf "../$lib" "$MULTIARCH_DIR/$lib" 2>/dev/null
            fi
        fi
    done
    cd - > /dev/null
fi

# Execute the real binary
exec "$SCRIPT_DIR/flm-real" "$@"

